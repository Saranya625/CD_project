//Wrong Inverse

int main() {
    matrix A[2][2] = {{2,1},{3,4}};
    matrix B[2][2];
    decimal d1;
    decimal d2;

    d1 = A.det;
    d2 = A.det; // CSE for det

    B = A.inv;
    A = A.inv;  // CSE for inv (reuse)

    print("d:", d1, d2);
    print("b:", B[0][0], B[1][1]);
    print("a:", A[0][0], A[1][1]);

    return 0;
}
