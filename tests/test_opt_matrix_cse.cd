int main() {
    matrix a[2][2] = {{1,2},{3,4}};
    matrix b[2][2] = {{5,6},{7,8}};
    matrix c[2][2];
    matrix d[2][2];

    c = a.mul(b);
    d = a.mul(b);  // should reuse c via matrix CSE

    print("c:", c[0][0], c[0][1], c[1][0], c[1][1]);
    print("d:", d[0][0], d[0][1], d[1][0], d[1][1]);
    return 0;
}
