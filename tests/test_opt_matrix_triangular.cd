int main() {
    matrix U[3][3] = {{1,2,3},{0,1,4},{0,0,1}}; // upper triangular, det = 1
    matrix Inv[3][3];
    decimal detv;

    detv = U.det;   // det = 1
    Inv = U.inv;    // inverse stays integer

    print("det:", detv);
    print("\ninv:", Inv[0][0], Inv[0][1], Inv[0][2]);

    return 0;
}
