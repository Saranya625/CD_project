int main() {
    matrix I[2][2] = {{1,0},{0,1}};
    matrix Z[2][2] = {{0,0},{0,0}};
    matrix A[2][2] = {{2,3},{4,5}};
    matrix B[2][2];
    matrix C[2][2];
    matrix D[2][2];
    matrix E[2][2];

    B = A.add(Z);  // A + 0 -> A
    C = A.mul(I);  // A * I -> A
    D = Z.mul(A);  // 0 * A -> 0
    E = A.T.T;     // transpose(transpose(A)) -> A
    decimal F = I.det;

    print("B:", B[0][0], B[0][1], B[1][0], B[1][1]);
    print("C:", C[0][0], C[0][1], C[1][0], C[1][1]);
    print("D:", D[0][0], D[0][1], D[1][0], D[1][1]);
    print("E:", E[0][0], E[0][1], E[1][0], E[1][1]);

    return 0;
}
