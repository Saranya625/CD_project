int main() {
    matrix a[1][1] = {{7}};
    matrix b[1][1] = {{3}};
    matrix c[1][1];
    matrix d[1][1];
    matrix e[1][1];

    c = a.add(b);  // scalar add
    d = a.mul(b);  // scalar mul
    e = a;         // scalar copy

    print("c:", c[0][0]);
    print("d:", d[0][0]);
    print("e:", e[0][0]);

    return 0;
}
