int main() {
    matrix a[2][2] = {{1,2},{3,4}};
    matrix b[2][2] = {{5,6},{7,8}};
    matrix c[2][2];
    matrix d[2][2];
    matrix e[2][2];
    matrix f[2][2];
    matrix g[2][2];

    // add/sub/mul/transpose/copy
    c = a.add(b);
    d = b.sub(a);
    e = a.mul(b);
    f = a.T;
    g = a;

    print("add:", c[0][0], c[0][1], c[1][0], c[1][1]);
    print("sub:", d[0][0], d[0][1], d[1][0], d[1][1]);
    print("mul:", e[0][0], e[0][1], e[1][0], e[1][1]);
    print("tr :", f[0][0], f[0][1], f[1][0], f[1][1]);
    print("cpy:", g[0][0], g[0][1], g[1][0], g[1][1]);

    return 0;
}
